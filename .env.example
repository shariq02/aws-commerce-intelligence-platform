# ====================================================================
# AWS Commerce Intelligence Platform - Environment Variables Example
# ====================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git - it is in .gitignore
# ====================================================================

# ====================================================================
# PROJECT
# ====================================================================

PROJECT_NAME=aws-commerce-intelligence-platform
ENVIRONMENT=development
LOG_LEVEL=INFO

# ====================================================================
# POSTGRESQL DATABASE
# ====================================================================

POSTGRES_HOST=172.31.32.1
POSTGRES_PORT=5432
POSTGRES_DB=acip
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ====================================================================
# REDPANDA (KAFKA-COMPATIBLE)
# ====================================================================

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=acip-producer
KAFKA_COMPRESSION_TYPE=gzip
KAFKA_ACKS=all
KAFKA_RETRIES=3
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10

# ====================================================================
# KAFKA TOPICS
# ====================================================================

TOPIC_ECOMMERCE=ecommerce.events
TOPIC_PHARMACY=pharmacy.events
TOPIC_MARKETPLACE=marketplace.events
TOPIC_ANOMALIES=platform.anomalies
TOPIC_DLQ=platform.dlq

# ====================================================================
# AWS
# ====================================================================

AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=eu-central-1
AWS_ACCOUNT_ID=your_account_id_here

# ====================================================================
# AWS S3
# ====================================================================

S3_BRONZE_BUCKET=acip-bronze
S3_SILVER_BUCKET=acip-silver
S3_GOLD_BUCKET=acip-gold

# ====================================================================
# AWS DYNAMODB
# ====================================================================

DYNAMODB_METRICS_TABLE=domain-realtime-metrics
DYNAMODB_ANOMALIES_TABLE=anomaly-flags
DYNAMODB_INVENTORY_TABLE=inventory-alerts
DYNAMODB_SELLER_TABLE=seller-sla-status
DYNAMODB_DLQ_TABLE=platform-dlq-status

# ====================================================================
# AWS SNS
# ====================================================================

SNS_ECOMMERCE_TOPIC_ARN=your_sns_arn_here
SNS_PHARMACY_TOPIC_ARN=your_sns_arn_here
SNS_MARKETPLACE_TOPIC_ARN=your_sns_arn_here
SNS_PLATFORM_TOPIC_ARN=your_sns_arn_here

# ====================================================================
# AWS GLUE SCHEMA REGISTRY
# ====================================================================

GLUE_REGISTRY_NAME=acip-schema-registry
GLUE_REGISTRY_ARN=your_registry_arn_here

# ====================================================================
# FLINK
# ====================================================================

FLINK_HOME=/home/sharique/flink
FLINK_CHECKPOINT_DIR=/tmp/flink-checkpoints
FLINK_CHECKPOINT_INTERVAL=60000
FLINK_WATERMARK_DELAY=300000

# ====================================================================
# DATABRICKS
# ====================================================================

DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_token_here

# ====================================================================
# PREFECT
# ====================================================================

PREFECT_API_URL=https://api.prefect.cloud/api/accounts/your_account_id/workspaces/your_workspace_id
PREFECT_API_KEY=your_prefect_api_key_here

# ====================================================================
# FASTAPI
# ====================================================================

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# ====================================================================
# DATA GENERATOR
# ====================================================================

GENERATOR_EVENTS_PER_SECOND=10
GENERATOR_REPLAY_SPEED=60
GENERATOR_ANOMALY_MODE=false
GENERATOR_ANOMALY_PROBABILITY=0.05

# ====================================================================
# BRONZE LAYER
# ====================================================================

BRONZE_POLL_TIMEOUT=1000
BRONZE_MAX_POLL_RECORDS=500
BRONZE_AUTO_OFFSET_RESET=earliest
BRONZE_PARQUET_BATCH_SIZE=1000
BRONZE_WRITE_INTERVAL=60
BRONZE_PARQUET_COMPRESSION=snappy
BRONZE_CHECKPOINT_INTERVAL=300

# ====================================================================
# SILVER LAYER
# ====================================================================

SILVER_COMPLETENESS_THRESHOLD=0.95
SILVER_UNIQUENESS_THRESHOLD=1.0
SILVER_BATCH_SIZE=10000

# ====================================================================
# GOLD LAYER
# ====================================================================

GOLD_SNAPSHOT_INTERVAL_HOURS=1
GOLD_RETENTION_DAYS=90
GOLD_AGGREGATION_BATCH_SIZE=50000

# ====================================================================
# GRAFANA
# ====================================================================

GRAFANA_HOST=localhost
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here
